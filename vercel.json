{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/auth/login",
      "destination": "/api/auth?_action=login"
    },
    {
      "source": "/api/auth/register",
      "destination": "/api/auth?_action=register"
    },
    {
      "source": "/api/students/self-evaluation",
      "destination": "/api/students?_resource=self-evaluation"
    },
    {
      "source": "/api/students/authorization",
      "destination": "/api/students?_resource=authorization"
    },
    {
      "source": "/api/teachers/checklist",
      "destination": "/api/teachers?_resource=checklist"
    },
    {
      "source": "/api/students/portfolio",
      "destination": "/api/students?_resource=portfolio"
    },
    {
      "source": "/api/students/logbook",
      "destination": "/api/students?_resource=logbook"
    },
    {
      "source": "/api/students/attendance",
      "destination": "/api/students?_resource=attendance"
    },
    {
      "source": "/api/teachers/validations",
      "destination": "/api/teachers?_resource=validations"
    },
    {
      "source": "/api/grades",
      "destination": "/api/teachers?_resource=grades"
    },
    {
      "source": "/api/teachers/visits",
      "destination": "/api/teachers?_resource=visits"
    },
    {
      "source": "/api/admin/dashboard",
      "destination": "/api/admin?_resource=dashboard"
    },
    {
      "source": "/api/admin/init",
      "destination": "/api/admin?_resource=init"
    },
    {
      "source": "/api/admin/notes",
      "destination": "/api/admin?_resource=notes"
    },
    {
      "source": "/api/students/pasantia",
      "destination": "/api/students?_resource=pasantia"
    },
    {
      "source": "/api/students/report",
      "destination": "/api/students?_resource=report"
    },
    {
      "source": "/api/admin/import",
      "destination": "/api/admin/import"
    },
    {
      "source": "/api/admin/users",
      "destination": "/api/admin/users"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,PUT,DELETE,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}